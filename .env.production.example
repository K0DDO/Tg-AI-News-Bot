# =============================================================================
# Production secrets for VPS + Docker Compose
#   cp .env.production.example .env.production
# Never commit .env.production.
# Compose uses: docker compose --env-file .env.production …
# =============================================================================

APP_ENV=production
APP_DEBUG=false
LOG_LEVEL=INFO
LOGS_DIR=/app/logs

# PostgreSQL (Docker service name = postgres)
POSTGRES_USER=briefly
POSTGRES_PASSWORD=change-me-strong-unique
POSTGRES_DB=briefly
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Leave empty — compose sets DATABASE_URL for briefly-app
DATABASE_URL=

# Redis (Docker service). Compose sets REDIS_URL=redis://redis:6379/0
REDIS_URL=redis://redis:6379/0

BOT_TOKEN=

# Numeric Telegram IDs only (comma-separated). Never usernames.
ADMIN_TELEGRAM_IDS=123456789
OWNER_TELEGRAM_ID=

# Telethon
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_NAME=news_parser
TELEGRAM_SESSION_DIR=/app/data/sessions

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong
ADMIN_SECRET_KEY=change-me-to-a-long-random-string

PARSER_POLL_INTERVAL_SECONDS=120
CLUSTER_SIMILARITY_THRESHOLD=0.75
CLUSTER_LOOKBACK_HOURS=48
DIGEST_DEFAULT_LIMIT=5
DAILY_DIGEST_LIMIT=10
MESSAGE_RETENTION_DAYS=31

# hashing required on ~2GB VPS
EMBEDDING_BACKEND=hashing
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# AI — comma-separated key pools (legacy GROQ_API_KEY still works)
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_API_KEYS=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TIMEOUT_SECONDS=45
KIMI_API_KEYS=
KIMI_MODEL=moonshot-v1-8k
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_TIMEOUT_SECONDS=60
AI_SEARCH_SYNTHESIS=true
AI_BATCH_SIZE=30
AI_CACHE_TTL_DAYS=30
