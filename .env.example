# Env templates (committed):
#   .env.local.example       → copy to .env.local       (Windows / local dev)
#   .env.production.example  → copy to .env.production  (VPS + Docker Compose)
#
# Runtime files (gitignored): .env.local | .env.production | legacy .env
#
# Precedence (app/config/settings.py):
#   BRIEFLY_ENV_FILE / ENV_FILE → explicit path
#   APP_ENV=production + .env.production
#   else .env.local, then legacy .env
# Docker Compose injects vars from .env.production; OS env always wins.

# Minimal reference — prefer the split examples above.
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO
LOGS_DIR=./data/logs

POSTGRES_USER=briefly
POSTGRES_PASSWORD=briefly
POSTGRES_DB=briefly
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=

REDIS_URL=redis://localhost:6379/0

BOT_TOKEN=

# Numeric Telegram IDs only — comma-separated (never usernames)
ADMIN_TELEGRAM_IDS=123456789
OWNER_TELEGRAM_ID=

TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_NAME=news_parser
TELEGRAM_SESSION_DIR=./data/sessions

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_SECRET_KEY=change-me

PARSER_POLL_INTERVAL_SECONDS=120
CLUSTER_SIMILARITY_THRESHOLD=0.75
CLUSTER_LOOKBACK_HOURS=48
DIGEST_DEFAULT_LIMIT=5
DAILY_DIGEST_LIMIT=10
MESSAGE_RETENTION_DAYS=31

EMBEDDING_BACKEND=hashing
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TIMEOUT_SECONDS=45
AI_SEARCH_SYNTHESIS=true
