# Application
APP_ENV=production
APP_DEBUG=false
LOG_LEVEL=INFO
LOGS_DIR=/app/logs

# PostgreSQL (internal Docker network only — do not publish ports)
POSTGRES_USER=briefly
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=briefly
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Overridden in compose for the app container; keep for local dev:
DATABASE_URL=postgresql+asyncpg://briefly:change-me-strong@localhost:5432/briefly

# Redis (FSM + short cache)
REDIS_URL=redis://localhost:6379/0

# Telegram Bot (aiogram) — long polling, no webhook
BOT_TOKEN=123456:ABC-DEF

# Comma-separated Telegram user ids for /status
ADMIN_TELEGRAM_IDS=

# Telethon (user account for reading channels)
TELEGRAM_API_ID=12345
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_SESSION_NAME=news_parser
TELEGRAM_SESSION_DIR=./data/sessions

# Optional local admin panel (not started by production compose)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_SECRET_KEY=change-me-to-a-long-random-string

# Pipeline
PARSER_POLL_INTERVAL_SECONDS=120
CLUSTER_SIMILARITY_THRESHOLD=0.75
CLUSTER_LOOKBACK_HOURS=48
DIGEST_DEFAULT_LIMIT=5
DAILY_DIGEST_LIMIT=10
MESSAGE_RETENTION_DAYS=31

# Embeddings: hashing (required on 2GB VPS) | sentence-transformers | auto
EMBEDDING_BACKEND=hashing
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# AI provider: heuristic | groq
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TIMEOUT_SECONDS=45
AI_SEARCH_SYNTHESIS=true
