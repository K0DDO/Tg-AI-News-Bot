# Application
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_USER=newsbot
POSTGRES_PASSWORD=newsbot
POSTGRES_DB=newsbot
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://newsbot:newsbot@localhost:5432/newsbot

# Telegram Bot (aiogram)
BOT_TOKEN=123456:ABC-DEF

# Telethon (user account for reading channels)
TELEGRAM_API_ID=12345
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_SESSION_NAME=news_parser
TELEGRAM_SESSION_DIR=./data/sessions

# Admin panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_SECRET_KEY=change-me-to-a-long-random-string

# Pipeline
PARSER_POLL_INTERVAL_SECONDS=120
CLUSTER_SIMILARITY_THRESHOLD=0.75
CLUSTER_LOOKBACK_HOURS=48
DIGEST_DEFAULT_LIMIT=5
DAILY_DIGEST_LIMIT=10
MESSAGE_RETENTION_DAYS=14

# Embeddings: hashing (recommended on 2GB VPS) | sentence-transformers | auto
EMBEDDING_BACKEND=hashing
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# AI provider: heuristic | groq
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TIMEOUT_SECONDS=45
AI_SEARCH_SYNTHESIS=true
