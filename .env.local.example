# =============================================================================
# Local development (Windows) — copy to .env.local and fill secrets
#   copy .env.local.example .env.local
# Do NOT use this file as production config. localhost is for local only.
# =============================================================================

APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO
LOGS_DIR=./data/logs

# PostgreSQL (local instance or Docker published only for dev)
POSTGRES_USER=briefly
POSTGRES_PASSWORD=briefly
POSTGRES_DB=briefly
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Leave empty to build from POSTGRES_* — or set explicitly:
# DATABASE_URL=postgresql+asyncpg://briefly:briefly@localhost:5432/briefly
DATABASE_URL=

# Redis optional locally (if down, FSM uses MemoryStorage)
REDIS_URL=redis://localhost:6379/0

# Telegram Bot (aiogram) — long polling
BOT_TOKEN=

# Admins: numeric Telegram IDs only (comma-separated). Never usernames.
# Find your id via @userinfobot or similar.
ADMIN_TELEGRAM_IDS=123456789
# Optional dedicated OWNER; if empty, first ADMIN_TELEGRAM_IDS is OWNER
OWNER_TELEGRAM_ID=

# Telethon (user account for reading channels)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_NAME=news_parser
TELEGRAM_SESSION_DIR=./data/sessions

# Local admin panel passwords (optional web UI; not used by compose prod)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_SECRET_KEY=change-me-local-dev-secret

# Pipeline
PARSER_POLL_INTERVAL_SECONDS=120
CLUSTER_SIMILARITY_THRESHOLD=0.75
CLUSTER_LOOKBACK_HOURS=48
DIGEST_DEFAULT_LIMIT=5
DAILY_DIGEST_LIMIT=10
MESSAGE_RETENTION_DAYS=31

EMBEDDING_BACKEND=hashing
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TIMEOUT_SECONDS=45
AI_SEARCH_SYNTHESIS=true
